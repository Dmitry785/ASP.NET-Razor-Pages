@page "{id:guid}"
@using Application.Services.Interfaces
@using Domain.Models
@model Program.Pages.MovieModel
@inject IDataAccessService<Movie> Movies;
@inject IDataAccessService<Schedule> Schedules;
@{
    ViewBag.Title = "Movie";
    Layout = "_Layout";
}
@{
    var movieResult = Movies.GetById(Model.Id);
    Movie movie = new Movie();
    if (movieResult.Success)
        movie = movieResult.Data!;
}
<div id ="return-container">
    <a asp-page="index">
        Return back to the home page
    </a>
</div>

<div class="current-movie-container">
    <img class="movie-poster" src="@movie.Poster" alt="Movie"/>
    <div class="movie-description-container">
        <h1 class="movie-name">@movie.Name</h1>
        <h1 class="movie-director">@movie.Director.FullName</h1>
        <h1 class="movie-genre">@movie.Genre.Name</h1>
        <h1 class="movie-description">@movie.Description</h1>
        <h1 class="movie-id">@movie.Id</h1>
        <h1 class="movie-year">@movie.Year</h1>
    </div>
</div>
<div class="schedules-container">
    @{
        var schedulesResult = Schedules.GetAll();
        if (schedulesResult.Success) {
            foreach (var schedule in schedulesResult.Data!.Where(x => x.Movie.Id == movie.Id))
            {
                <div class="schedule-item">
                    <h1 class="schedule-item-session-time">@schedule.SessionTime.ToString("yyyy-MM-dd")</h1>
                </div>
            }
        }
    }
</div>

<style>
    #return-container {
        margin: 20px;
        border-radius: 10px;
        display: inline-block;
        background-color: white;
        padding: 10px 30px;
    }
    #return-container a{
            text-decoration: none;
            color: inherit;
    }
    .schedule-item{
        flex-shrink: 0;
        background: linear-gradient(45deg, blue, green, lightblue, blue);
        height: 200px;
        width: 150px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 2px solid black;
    }
    .schedule-item-session-time{
        font-size: 20px;
    }
    .current-movie-container {
        display: flex;
        gap: 20px;
        margin: 5px 0;
        background-color: rgba(255, 255, 255, 0.8);
        padding: 20px;
    }
    .schedules-container {
        display: flex;
        overflow-x: auto;
        justify-content: flex-start;
        gap: 20px;
        margin: 5px;
        background-color: rgba(200, 255, 255, 0.8);
        padding: 20px;
    }
    .movie-poster {
        flex: 0 0 auto;
        margin-right: auto;
        overflow: hidden;
        margin: 0 auto;
    }
    .movie-description {
        font-size: 16px;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .movie-id {
        font-size: 14px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .movie-description-container {
        flex: 0 0 50%;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 20px;
    }
    .movie-name {
        font-size: 20px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    .movie-director {
        font-weight: normal;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        font-size: 18px;
    }
    .movie-genre {
        font-size: 15px;
    }
    .movie-year {
        font-size: 18px;
    }
    .movie-year {
        font-size: 18px;
    }
</style>