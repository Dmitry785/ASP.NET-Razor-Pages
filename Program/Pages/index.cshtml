@page
@model Program.Pages.IndexModel
@using Domain.Models;
@using Application.Services.Interfaces;
@inject IDataAccessService<Movie> Movies;
@{
    Layout = "_Layout";
}
<div class="movies-container">
    @{
        var moviesResult = Movies.GetAll();
        if(moviesResult.Success){
            foreach (var movie in moviesResult.Data!)
            {
                <div class="movie-item" data-id="@movie.Id">
                    <img class="movie-item-poster" src="@movie.Poster"/>
                    <h1 class="movie-item-name">@movie.Name</h1>
                    <h1 class="movie-item-director">@movie.Director.FullName</h1>
                    <h1 class="movie-item-genre">@movie.Genre.Name</h1>
                    <h1 class="movie-item-year">@movie.Year</h1>
                </div>
            }
        }
    }
</div>

<style>
    .movies-container {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 5px;
        margin: 5px 0;
        background-color: rgba(255, 255, 255, 0.8);
        padding: 10px;
        min-height: 100vh;
        align-items: flex-start;
    }

    .movie-item { 
        border-radius: 10px;
        overflow: hidden;
        display: flex;
        width: 250px;
        background-color: darkgray;
        flex-direction: column;
    }

    .movie-item-poster {
        padding: 10px;
        flex: 0 0 300px;
        object-fit: contain;
        background: darkgreen;
        overflow: hidden;
    }

    .movie-item-name {
        flex-shrink: 0;
        padding: 3px;
        font-size: 20px;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin: 0;
    }

    .movie-item-director {
        flex-shrink: 0;
        font-weight: normal;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        padding: 0 10px;
        font-size: 18px;
        margin: 0;
    }

    .movie-item-genre {
        flex-shrink: 0;
        font-size: 15px;
        margin: auto 10px 0 auto;
        text-shadow: 2px 1px gray;
    }

    .movie-item-year {
        flex-shrink: 0;
        font-size: 18px;
        padding: 0 3px 5px 0;
        margin: 5px 5px 0 auto;
    }

    .movie-item-year {
        flex-shrink: 0;
        font-size: 18px;
    }
</style>

<script>
    $(document).ready(function () {
        $('.movie-item').click(function () {
            window.location.href = `/game?id=${$(this).data().id}`;
        }).mouseenter(function () {
            $(this).children('.movie-item-poster').stop(true, true).fadeTo('fast', 0.7, function () {
                $(this).fadeTo('fast', 1);
            });
        });
    })
</script>